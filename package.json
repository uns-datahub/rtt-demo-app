{
  "name": "rtt-demo-app",
  "version": "6.1.11",
  "private": true,
  "description": "RTT demo UNS app with MQTT simulation and calculated power API endpoint",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/uns-datahub/rtt-demo-app.git"
  },
  "homepage": "https://github.com/uns-datahub/rtt-demo-app#readme",
  "bugs": {
    "url": "https://github.com/uns-datahub/rtt-demo-app/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "verify": "pnpm run build",
    "dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "start": "node dist/index.js",
    "hrm:submit": "tsx scripts/hrm-submit.ts",
    "hrm:watch": "tsx scripts/hrm-watch.ts",
    "subasset:example": "tsx scripts/subasset-publish-example.ts",
    "generate-config-schema": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/generate-config-schema.js",
    "generate-uns-dictionary": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/generate-uns-dictionary.js",
    "generate-uns-measurements": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/generate-uns-measurements.js",
    "generate-uns-reference": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/generate-uns-reference.js",
    "generate-uns-topics-tags": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/refresh-uns.js",
    "sync-uns-schema": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/sync-uns-schema.js",
    "sync-uns-metadata": "node --preserve-symlinks-main ./node_modules/@uns-kit/core/dist/tools/sync-uns-metadata.js"
  },
  "dependencies": {
    "@uns-kit/api": "^3.0.5",
    "@uns-kit/core": "^3.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "prettier": "^3.9.6",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "zod-to-json-schema": "^3.25.2",
    "zod-to-ts": "^1.2.0"
  },
  "packageManager": "pnpm@10.30.3"
}
