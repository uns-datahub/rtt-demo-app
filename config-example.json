{
  "uns": {
    "graphql": "http://localhost:8180/graphql",
    "rest": "http://localhost:8180/api",
    "processName": "rtt-demo-app",
    "instanceMode": "wait",
    "handover": true,
    "jwksWellKnownUrl": "http://localhost:8180/api/.well-known/jwks.json",
    "kidWellKnownUrl": "http://localhost:8180/api/.well-known/kid",
    "email": "user@example.com",
    "password": {
      "provider": "env",
      "key": "UNS_PASSWORD"
    }
  },
  "infra": {
    "host": "localhost"
  },
  "output": {
    "host": "localhost"
  },
  "input": {
    "host": "localhost"
  },
  "hrm": {
    "topicBase": "demo/steelworks/hot-rolling/",
    "tickIntervalMs": 1000,
    "simulationSpeed": 30,
    "simulationResolution": 100,
    "productionLine": {
      "furnace": {
        "assetId": "hrm-pusher-furnace",
        "description": "Potisna peč (reheating furnace)",
        "zones": 4,
        "maxTempC": 1280,
        "gasConsumptionNm3PerHour": 800
      },
      "descaling": {
        "assetId": "hrm-descaling",
        "description": "Hidravlično odstranjevanje okajne plasti",
        "nominalPressureBar": 200,
        "nominalFlowM3PerHour": 12,
        "durationMin": 5
      },
      "rollingStand": {
        "assetId": "hrm-stand-1",
        "description": "Reverzirno valjarsko ogrodje",
        "nominalSpeedMps": 2.5,
        "maxMotorPowerKw": 3500,
        "maxForceKn": 18000,
        "durationMinPerPass": 3
      },
      "warehouse": {
        "assetId": "hrm-warehouse",
        "description": "Skladišče in laboratorij kakovosti"
      }
    },
    "recipes": [
      {
        "id": "s355-20mm",
        "name": "Jeklo S355 20 mm",
        "materialType": "S355",
        "targetThicknessMm": 20,
        "targetWidthMm": 1500,
        "initialThicknessMm": 200,
        "furnace": {
          "targetTempC": 1200,
          "pusherPaceMin": 12,
          "stoichiometricRatioTarget": 1.03,
          "soakingTimeMin": 45,
          "zones": [
            { "zoneId": 1, "setpointC": 900 },
            { "zoneId": 2, "setpointC": 1100 },
            { "zoneId": 3, "setpointC": 1200 },
            { "zoneId": 4, "setpointC": 1200 }
          ]
        },
        "rollingPlan": {
          "passes": [
            { "passNumber": 1, "direction": "forward", "targetThicknessMm": 120, "speedMps": 1.5 },
            { "passNumber": 2, "direction": "reverse", "targetThicknessMm": 80,  "speedMps": 1.8 },
            { "passNumber": 3, "direction": "forward", "targetThicknessMm": 50,  "speedMps": 2.2 },
            { "passNumber": 4, "direction": "reverse", "targetThicknessMm": 30,  "speedMps": 2.8 },
            { "passNumber": 5, "direction": "forward", "targetThicknessMm": 20,  "speedMps": 3.5 }
          ]
        }
      }
    ],
    "qualitySpecs": [
      {
        "id": "qs-s355-20mm",
        "name": "Laboratorijski standard S355 20 mm",
        "applicableMaterialType": "S355",
        "idealThicknessMm": 20.0,
        "thicknessToleranceMm": 0.3,
        "idealExitTempC": 850,
        "exitTempToleranceC": 30,
        "minHardnessHB": 130,
        "maxHardnessHB": 155,
        "surfaceGrade": "A"
      }
    ]
  }
}
