{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "index (dist)",
      "runtimeArgs": [
        "--enable-source-maps"
      ],
      "program": "${workspaceFolder}/dist/index.js",
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "outputCapture": "std",
      "sourceMaps": true,
      "stopOnEntry": false,
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js",
        "!**/node_modules/**"
      ],
      "skipFiles": ["<node_internals>/**"],
      "preLaunchTask": "tsc: watch"
    }
  ]
}
